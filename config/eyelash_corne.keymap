#define ZMK_POINTING_DEFAULT_MOVE_VAL 1200  // 600
#define ZMK_POINTING_DEFAULT_SCRL_VAL 25   // 10

#include <input/processors.dtsi>
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/outputs.h>
#include <dt-bindings/zmk/pointing.h>
#include <dt-bindings/zmk/rgb.h>

&mmv_input_listener { input-processors = <&zip_xy_scaler 2 1>; };

&msc_input_listener { input-processors = <&zip_scroll_scaler 2 1>; };

&msc {
    acceleration-exponent = <1>;      // 0
    time-to-max-speed-ms = <100>;       // 300
    delay-ms = <0>;                   // 0
};

&mmv {
    time-to-max-speed-ms = <500>;
    acceleration-exponent = <1>;
    trigger-period-ms = <16>;
};

&soft_off { hold-time-ms = <2000>; };

/ {
    behaviors {
        // Shift tap-dance: single tap = oneshot shift, double tap = caps word
        // Holding oneshot shift works as held shift (built into ZMK sticky key)
        td_shift: td_shift {
            compatible = "zmk,behavior-tap-dance";
            display-name = "Shift/CapsWord";
            #binding-cells = <0>;
            bindings = <&sk LSHFT>, <&caps_word>;
        };
    };

    // Tmux prefix macro: outputs Ctrl+B in a single keypress
    macros {
        tmux_prefix: tmux_prefix {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&macro_press &kp LCTRL>, <&macro_tap &kp B>, <&macro_release &kp LCTRL>;
        };
    };

    rgb_encoder: rgb_encoder {
        compatible = "zmk,behavior-sensor-rotate";
        #sensor-binding-cells = <0>;
        bindings = <&rgb_ug RGB_BRI>, <&rgb_ug RGB_BRD>;
    };

    scroll_encoder: scroll_encoder {
        compatible = "zmk,behavior-sensor-rotate";
        #sensor-binding-cells = <0>;
        bindings = <&msc SCRL_DOWN>, <&msc SCRL_UP>;

        tap-ms = <100>;
    };

    combos {
        compatible = "zmk,combos";

        // Soft power off: Q + R + Z (physical positions 1 + 15 + 29)
        softoff {
            bindings = <&soft_off>;
            key-positions = <1 15 29>;
        };

        // Vim Escape: N + E simultaneously (right home row, index + middle in Colemak-DH)
        vim_esc {
            bindings = <&kp ESC>;
            key-positions = <23 24>;
            timeout-ms = <30>;
        };

        // Backspace: E + I simultaneously (right home row, middle + ring in Colemak-DH)
        combo_bspc {
            bindings = <&kp BSPC>;
            key-positions = <24 25>;
            timeout-ms = <30>;
        };

        // Backtick: Tab + Q simultaneously (top-left corner of left half)
        combo_grave {
            bindings = <&kp GRAVE>;
            key-positions = <0 1>;
            timeout-ms = <30>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        // ==========================================
        // LAYER 0: COLEMAK-DH (base)
        // ==========================================
        // Left column:  Tab (top), Ctrl (home), Shift (bottom)
        // Right column: Bspc (top), [Quote home], Shift/CapsWord (bottom)
        // Left thumbs:  Alt (outer), Cmd/Super (middle), Nav/mo3 (inner)
        // Right thumbs: Space/Nav (inner), Enter/Num (middle), Sym/mo2 (outer)
        // Combos: N+E=Esc, E+I=Bspc, Tab+Q=Backtick
        default_layer {
            display-name = "COLEMAK-DH";
            bindings = <
&kp TAB     &kp Q  &kp W  &kp F      &kp P     &kp B                               &kp UP                &kp J        &kp L  &kp U      &kp Y    &kp SEMI  &kp BSPC
&kp LCTRL   &kp A  &kp R  &kp S      &kp T     &kp G                     &kp LEFT  &kp ENTER  &kp RIGHT  &kp M        &kp N  &kp E      &kp I    &kp O     &kp SQT
&kp LSHFT   &kp Z  &kp X  &kp C      &kp D     &kp V        &kp SPACE              &kp DOWN              &kp K        &kp H  &kp COMMA  &kp DOT  &kp FSLH  &td_shift
                           &kp LALT   &kp LGUI  &mo 3                                                     &lt 3 SPACE  &lt 1 ENTER  &mo 2
            >;

            sensor-bindings = <&inc_dec_kp C_VOLUME_UP C_VOL_DN>;
        };

        // ==========================================
        // LAYER 1: NUMBER (hold right middle thumb / Enter)
        // ==========================================
        // BT safety: BT_CLR_ALL on bottom-left (Z position)
        // BT profiles: R=BT0, S=BT1, T=BT2, G=BT3
        lower_layer {
            display-name = "NUMBER";
            bindings = <
&trans  &kp N1           &kp N2          &kp N3        &kp N4        &kp N5                                         &mmv MOVE_UP                     &kp N6           &kp N7           &kp N8           &kp N9           &kp N0    &kp BSPC
&trans  &none            &bt BT_SEL 0    &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3                   &mmv MOVE_LEFT  &mkp LCLK       &mmv MOVE_RIGHT  &kp LEFT         &kp DOWN         &kp UP           &kp RIGHT        &kp HOME  &kp PG_UP
&trans  &bt BT_CLR_ALL   &rgb_ug RGB_ON  &trans        &trans        &rgb_ug RGB_EFF  &kp C_MUTE                    &mmv MOVE_DOWN                   &rgb_ug RGB_EFR  &rgb_ug RGB_SPI  &rgb_ug RGB_BRI  &rgb_ug RGB_BRD  &kp END   &kp PG_DN
                                         &trans        &trans        &trans                                                                          &kp INS          &trans           &kp DEL
            >;

            sensor-bindings = <&scroll_encoder>;
        };

        // ==========================================
        // LAYER 2: SYMBOL (hold right outer thumb)
        // ==========================================
        // Top-left = backtick (instead of &trans)
        raise_layer {
            display-name = "SYMBOL";
            bindings = <
&kp GRAVE  &kp EXCL      &kp AT        &kp HASH   &kp DLLR   &kp PRCNT                            &mmv MOVE_UP                     &kp CARET  &kp AMPS   &kp ASTRK  &kp LPAR  &kp RPAR  &kp BSPC
&trans     &bt BT_CLR    &mkp LCLK     &mkp MCLK  &mkp RCLK  &mkp MB4             &mmv MOVE_LEFT  &mkp LCLK       &mmv MOVE_RIGHT  &kp MINUS  &kp EQUAL  &kp LBKT   &kp RBKT  &kp BSLH  &kp GRAVE
&trans     &out OUT_USB  &out OUT_BLE  &none      &none      &mkp MB5   &trans                    &mmv MOVE_DOWN                   &kp UNDER  &kp PLUS   &kp LBRC   &kp RBRC  &kp PIPE  &kp TILDE
                                       &trans     &trans     &trans                                                                &kp SPACE  &kp RET    &trans
            >;

            sensor-bindings = <&scroll_encoder>;
        };

        // ==========================================
        // LAYER 3: Fn / Nav (hold left inner thumb or right inner thumb / Space)
        // ==========================================
        // Tmux prefix macro on left home row (R position)
        layer_3 {
            display-name = "Fn";
            bindings = <
&studio_unlock  &kp F1          &kp F2     &kp F3       &kp F4     &kp F5                                  &mmv MOVE_UP                     &kp F6       &kp F7     &kp F8       &kp F9      &kp F10          &kp F11
&trans          &tmux_prefix    &mkp LCLK  &mkp MCLK    &mkp RCLK  &mkp MB4                &mmv MOVE_LEFT  &mkp LCLK       &mmv MOVE_RIGHT  &bootloader  &mkp LCLK  &mkp MCLK    &mkp RCLK   &kp PRINTSCREEN  &kp F12
&trans          &sys_reset      &trans     &bootloader  &trans     &mkp MB5  &kp C_MUTE                    &mmv MOVE_DOWN                   &trans       &trans     &bootloader  &sys_reset  &kp SCROLLLOCK   &kp PAUSE_BREAK
                                           &trans       &trans     &trans                                                                   &trans       &trans     &trans
            >;

            sensor-bindings = <&scroll_encoder>;
        };
    };
};
